{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "flutter: analyze",
            "type": "flutter",
            "command": "flutter",
            "args": ["analyze"],
            "group": "build",
            "problemMatcher": ["$dartAnalyzer"]
        },
        {
            "label": "flutter: build APK",
            "type": "flutter",
            "command": "flutter",
            "args": ["build", "apk", "--release"],
            "group": "build"
        },
        {
            "label": "flutter: run all tests",
            "type": "flutter",
            "command": "flutter",
            "args": ["test"],
            "group": "test"
        },
        {
            "label": "flutter: clean",
            "type": "flutter",
            "command": "flutter",
            "args": ["clean"],
            "group": "build"
        },
        {
            "label": "flutter: pub get",
            "type": "flutter",
            "command": "flutter",
            "args": ["pub", "get"],
            "group": "build"
        }
    ]
}
